# ==============================================================
# Agno Runtime Platform - Environment Configuration
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# This is the ONLY place runtime configuration is read from. Nothing in
# docker-compose.yml or the Dockerfile overrides these values - it just
# loads this file verbatim via `env_file: .env`. Editing .env (and
# restarting the container) is the only thing required to change where
# this service connects.
#
# IMPORTANT - "localhost" means something different depending on how
# you run this service:
#   - Running directly on your machine (uvicorn / python -m ...):
#       localhost = your machine. Use the defaults below as-is if
#       Postgres/Redis/MCP Gateway are also running on your machine.
#   - Running via `docker compose up` (this container):
#       localhost = the container itself, NOT your host machine or other
#       containers. You MUST change every *_URL below to either:
#         a) host.docker.internal  - to reach services running on your
#            host machine (Docker Desktop on Mac/Windows; on Linux add
#            `extra_hosts: ["host.docker.internal:host-gateway"]` to the
#            agno-runtime service in docker-compose.yml, or use the
#            host's LAN/bridge IP instead), or
#         b) the actual hostname/IP of wherever Postgres/Redis/MCP
#            Gateway actually run (another container's service name if
#            it's on the same Docker network via --network, a remote
#            host, a managed DB endpoint, etc.)
#       Example for Docker Desktop (Mac/Windows) talking to services on
#       your host machine:
#         DATABASE_URL=postgresql+asyncpg://agno:agno@host.docker.internal:5432/agno_runtime
#         REDIS_URL=redis://host.docker.internal:6379/0
#         MCP_GATEWAY_SSE_URL=http://host.docker.internal:8100/sse
# ==============================================================

# --- App identity ---
APP_NAME=agno-runtime-platform
APP_ENV=local
APP_VERSION=1.0.0
LOG_LEVEL=INFO
LOG_JSON=true

# --- HTTP server ---
# PORT is also read by docker-compose.yml to set the host-side port
# mapping (${PORT:-8080}:8080) - change it here only, not in compose.
HOST=0.0.0.0
PORT=8080

# --- Database ---
# Async (asyncpg) - used by the running application.
DATABASE_URL=postgresql+asyncpg://agno:agno@localhost:5432/agno_runtime
# Sync (psycopg2) - used by Alembic migrations (run automatically by
# docker/entrypoint.sh on container start). Must point at the SAME
# database as DATABASE_URL above, just with a sync-capable driver.
DATABASE_URL_SYNC=postgresql+psycopg2://agno:agno@localhost:5432/agno_runtime
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_EVENT_STREAM_TTL_SECONDS=3600

# --- MCP Gateway ---
# MCP Gateway Core exposes a real MCP server over SSE (its mcp_server/
# package, default port 8100, path /sse). Agno Runtime connects as an
# MCP client over this single endpoint. It never enforces authorization
# itself - it only forwards the inbound Authorization / X-API-Key header
# verbatim as SSE connection headers; MCP Gateway is solely responsible
# for RBAC, permission enforcement, and routing each tool call to the
# right backend provider.
MCP_GATEWAY_SSE_URL=http://localhost:8100/sse
MCP_GATEWAY_TIMEOUT_SECONDS=30

# --- Auth propagation header names (forwarded verbatim, never validated) ---
FORWARD_HEADER_AUTHORIZATION=Authorization
FORWARD_HEADER_API_KEY=X-API-Key
FORWARD_HEADER_CORRELATION_ID=X-Correlation-ID

# --- Default model + provider keys ---
# These are FALLBACK credentials only, used when a model_registry entry
# doesn't set its own `api_key`. base_url, api_key, and extra_client_params
# are configured PER ENTRY via POST /api/v1/models (provider="openai_like"
# for local models / self-hosted / third-party OpenAI-compatible endpoints,
# e.g. http://localhost:11434/v1 for Ollama) - no env vars needed for that.
# Same Docker localhost caveat applies if you point base_url at a local
# model server while running this service in a container.
DEFAULT_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Keycloak (reference only - token issuer info; runtime does not validate tokens) ---
KEYCLOAK_ISSUER_URL=
KEYCLOAK_REALM=

# --- Observability ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=agno-runtime

# --- SSE / Streaming ---
SSE_KEEPALIVE_SECONDS=15
