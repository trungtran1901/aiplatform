# ==============================================================
# Agno Runtime Platform - Environment Configuration
# Copy this file to `.env` and fill in real values before running.
# ==============================================================

# --- App identity ---
APP_NAME=agno-runtime-platform
APP_ENV=local
APP_VERSION=1.0.0
LOG_LEVEL=INFO
LOG_JSON=true

# --- HTTP server ---
HOST=0.0.0.0
PORT=8080

# --- Database ---
# Async (asyncpg) - used by the running application
DATABASE_URL=postgresql+asyncpg://agno:agno@localhost:5432/agno_runtime
# Sync (psycopg2) - used by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg2://agno:agno@localhost:5432/agno_runtime
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_EVENT_STREAM_TTL_SECONDS=3600

# --- MCP Gateway ---
# MCP Gateway Core exposes a real MCP server over SSE (its mcp_server/
# package, default port 8100, path /sse). Agno Runtime connects as an
# MCP client over this single endpoint. It never enforces authorization
# itself - it only forwards the inbound Authorization / X-API-Key header
# verbatim as SSE connection headers; MCP Gateway is solely responsible
# for RBAC, permission enforcement, and routing each tool call to the
# right backend provider.
MCP_GATEWAY_SSE_URL=http://localhost:8100/sse
MCP_GATEWAY_TIMEOUT_SECONDS=30

# --- Auth propagation header names (forwarded verbatim, never validated) ---
FORWARD_HEADER_AUTHORIZATION=Authorization
FORWARD_HEADER_API_KEY=X-API-Key
FORWARD_HEADER_CORRELATION_ID=X-Correlation-ID

# --- Default model + provider keys ---
# These are FALLBACK credentials only, used when a model_registry entry
# doesn't set its own `api_key`. base_url, api_key, and extra_client_params
# are configured PER ENTRY via POST /api/v1/models (provider="openai_like"
# for local models / self-hosted / third-party OpenAI-compatible endpoints,
# e.g. http://localhost:11434/v1 for Ollama) - no env vars needed for that.
DEFAULT_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Keycloak (reference only - token issuer info; runtime does not validate tokens) ---
KEYCLOAK_ISSUER_URL=
KEYCLOAK_REALM=
 
# --- Observability ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=agno-runtime

# --- SSE / Streaming ---
SSE_KEEPALIVE_SECONDS=15
